YOUTUBE_API_KEY=your-youtube-api-key
RAPIDAPI_KEY=your-rapid-api-key

# Connection string to the external Postgres instance (running on the Docker host
# or any other reachable server). Format:
# postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
DB_URL=postgresql+psycopg2://absa:absa@host.docker.internal:5432/absa

# Pipeline parameters used by main.py when running non-interactively in Docker.
SEARCH_QUERY=iphone 15
SEARCH_LIMIT=50